<section class="wrap">
  <div class="product">
    <div class="product__media">
      {% if product.featured_image %}
        <img src="{{ product.featured_image | image_url: width: 1200 }}" alt="{{ product.featured_image.alt | escape }}">
      {% else %}
        <div style="aspect-ratio:1;display:grid;place-items:center">
          <img src="{{ 'logo.png' | asset_url }}" alt="{{ product.title }}" width="160" style="border-radius:24px">
        </div>
      {% endif %}
    </div>

    <div class="product__info">
      <span class="pill">{{ product.type | default: 'Software license' }}</span>
      <h1 class="product__title">{{ product.title }}</h1>

      <div class="product__price">
        {% if product.compare_at_price > product.price %}<s>{{ product.compare_at_price | money }}</s>{% endif %}
        {{ product.price | money }}
      </div>

      {% if product.description != blank %}
        <div class="rte">{{ product.description }}</div>
      {% endif %}

      {%- form 'product', product -%}
        {% unless product.has_only_default_variant %}
          {% for option in product.options_with_values %}
            <label for="opt-{{ option.position }}">{{ option.name }}</label>
            <select id="opt-{{ option.position }}" name="options[{{ option.name | escape }}]">
              {% for value in option.values %}
                <option value="{{ value | escape }}" {% if option.selected_value == value %}selected{% endif %}>{{ value }}</option>
              {% endfor %}
            </select>
          {% endfor %}
        {% endunless %}

        <input type="hidden" name="id" value="{{ product.selected_or_first_available_variant.id }}">

        <button type="submit" name="add" class="btn btn--primary btn--lg btn--block"
          {% unless product.available %}disabled{% endunless %}>
          {% if product.available %}{{ 'products.product.add_to_cart' | t }}{% else %}{{ 'products.product.sold_out' | t }}{% endif %}
        </button>
      {%- endform -%}

      <ul class="checklist">
        {% for block in section.blocks %}
          {% if block.type == 'perk' %}
            <li {{ block.shopify_attributes }}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"><path d="M20 6 9 17l-5-5"/></svg>
              <span>{{ block.settings.text }}</span>
            </li>
          {% endif %}
        {% endfor %}
      </ul>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Product",
  "blocks": [
    { "type": "perk", "name": "Perk", "settings": [
      { "type": "text", "id": "text", "label": "Text", "default": "Instant license delivery by email" }
    ]}
  ],
  "default": {
    "blocks": [
      { "type": "perk", "settings": { "text": "Instant license delivery by email" } },
      { "type": "perk", "settings": { "text": "Windows, macOS & Linux" } },
      { "type": "perk", "settings": { "text": "Free updates within your major version" } },
      { "type": "perk", "settings": { "text": "30-day refund policy" } }
    ]
  }
}
{% endschema %}
