<section class="hero" style="padding:72px 0 32px">
  <div class="wrap hero__inner center">
    {% if section.settings.eyebrow != blank %}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
    <h1>{{ section.settings.heading | default: page.title }}</h1>
    {% if section.settings.subheading != blank %}<p class="lead" style="margin:14px auto 0">{{ section.settings.subheading }}</p>{% endif %}
  </div>
</section>

{% schema %}
{
  "name": "Page hero",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading (defaults to page title)" },
    { "type": "textarea", "id": "subheading", "label": "Subheading" }
  ],
  "presets": [{ "name": "Page hero" }]
}
{% endschema %}
