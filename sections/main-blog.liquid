<section class="wrap">
  <div class="page-head"><h1>{{ blog.title }}</h1></div>
  <div class="collection-grid">
    {% for article in blog.articles %}
      <a href="{{ article.url }}" class="card">
        <div class="card__media">
          {% if article.image %}<img src="{{ article.image | image_url: width: 600 }}" alt="{{ article.title | escape }}">{% else %}<img src="{{ 'logo.png' | asset_url }}" width="80" style="border-radius:14px">{% endif %}
        </div>
        <div class="card__body">
          <span class="muted" style="font-size:.8rem">{{ article.published_at | date: '%b %d, %Y' }}</span>
          <span class="card__title">{{ article.title }}</span>
          <span class="muted" style="font-size:.9rem">{{ article.excerpt_or_content | strip_html | truncatewords: 20 }}</span>
        </div>
      </a>
    {% endfor %}
  </div>
</section>

{% schema %}
{ "name": "Blog" }
{% endschema %}
