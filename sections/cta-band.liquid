<section class="section cta-band">
  <div class="wrap center">
    <h2>{{ section.settings.heading }}</h2>
    <p class="lead" style="margin:0 auto 26px">{{ section.settings.subheading }}</p>
    <div class="btn-row" style="justify-content:center">
      {% if section.settings.primary_url != blank %}<a href="{{ section.settings.primary_url }}" class="btn btn--primary btn--lg">{{ section.settings.primary_label }}</a>{% endif %}
      {% if section.settings.secondary_url != blank %}<a href="{{ section.settings.secondary_url }}" class="btn btn--ghost btn--lg">{{ section.settings.secondary_label }}</a>{% endif %}
    </div>
    {% if section.settings.meta != blank %}<p class="hero__meta">{{ section.settings.meta }}</p>{% endif %}
  </div>
</section>

{% schema %}
{
  "name": "CTA band",
  "settings": [
    { "type": "text", "id": "heading", "label": "Heading", "default": "Stop waiting on progress bars." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Download OPENXMLJSON and open your biggest file in seconds." },
    { "type": "text", "id": "primary_label", "label": "Primary label", "default": "Download Essential" },
    { "type": "url", "id": "primary_url", "label": "Primary URL" },
    { "type": "text", "id": "secondary_label", "label": "Secondary label", "default": "Compare editions" },
    { "type": "url", "id": "secondary_url", "label": "Secondary URL" },
    { "type": "text", "id": "meta", "label": "Meta line", "default": "Windows · macOS · Linux · Essential edition available" }
  ],
  "presets": [{ "name": "CTA band" }]
}
{% endschema %}
