<section class="section {% if section.settings.alt %}section--alt{% endif %}">
  <div class="wrap" style="max-width:760px">
    {% if section.settings.eyebrow != blank %}<span class="eyebrow">{{ section.settings.eyebrow }}</span>{% endif %}
    {% if section.settings.heading != blank %}<h2>{{ section.settings.heading }}</h2>{% endif %}
    <div class="rte">{{ section.settings.body }}</div>
  </div>
</section>

{% schema %}
{
  "name": "Rich text",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow" },
    { "type": "text", "id": "heading", "label": "Heading" },
    { "type": "richtext", "id": "body", "label": "Body", "default": "<p>Tell your story here.</p>" },
    { "type": "checkbox", "id": "alt", "label": "Alt background", "default": false }
  ],
  "presets": [{ "name": "Rich text" }]
}
{% endschema %}
