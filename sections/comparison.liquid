<section class="section section--alt">
  <div class="wrap">
    <div class="center">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p class="lead">{{ section.settings.subheading }}</p>
    </div>
    <div class="compare">
      <table>
        <thead>
          <tr>
            <th></th>
            <th class="us">{{ section.settings.col_us }}</th>
            <th>{{ section.settings.col_a }}</th>
            <th>{{ section.settings.col_b }}</th>
          </tr>
        </thead>
        <tbody>
          {% for block in section.blocks %}
            <tr {{ block.shopify_attributes }}>
              <th scope="row">{{ block.settings.feature }}</th>
              <td class="col-us">{% render 'cell', v: block.settings.us %}</td>
              <td>{% render 'cell', v: block.settings.a %}</td>
              <td>{% render 'cell', v: block.settings.b %}</td>
            </tr>
          {% endfor %}
        </tbody>
      </table>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Comparison table",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How it compares" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Other tools weren't built for gigabytes." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "General-purpose editors treat JSON as plain text. OPENXMLJSON treats it as structured data." },
    { "type": "text", "id": "col_us", "label": "Our column", "default": "OPENXMLJSON" },
    { "type": "text", "id": "col_a", "label": "Column A", "default": "Text editors" },
    { "type": "text", "id": "col_b", "label": "Column B", "default": "Browser / online" }
  ],
  "blocks": [
    { "type": "row", "name": "Row", "settings": [
      { "type": "text", "id": "feature", "label": "Feature" },
      { "type": "text", "id": "us", "label": "Ours (use ✓ / ✕ / text)", "default": "✓" },
      { "type": "text", "id": "a", "label": "Column A value", "default": "✕" },
      { "type": "text", "id": "b", "label": "Column B value", "default": "✕" }
    ]}
  ],
  "presets": [{
    "name": "Comparison table",
    "blocks": [
      { "type": "row", "settings": { "feature": "Opens 10 GB files", "us": "✓", "a": "✕", "b": "✕" } },
      { "type": "row", "settings": { "feature": "Memory tracks working set, not file size", "us": "✓", "a": "✕", "b": "✕" } },
      { "type": "row", "settings": { "feature": "Structural tree navigation", "us": "✓", "a": "✕", "b": "Limited" } },
      { "type": "row", "settings": { "feature": "Parallel regex search", "us": "✓", "a": "Slow", "b": "✕" } },
      { "type": "row", "settings": { "feature": "JSONPath / XPath queries", "us": "✓", "a": "✕", "b": "✕" } },
      { "type": "row", "settings": { "feature": "Follow a live / growing file", "us": "✓", "a": "✕", "b": "✕" } },
      { "type": "row", "settings": { "feature": "Cross-format convert (JSON/XML/CSV)", "us": "✓", "a": "✕", "b": "Partial" } },
      { "type": "row", "settings": { "feature": "Data never leaves your machine", "us": "✓", "a": "✓", "b": "✕" } }
    ]
  }]
}
{% endschema %}
