<section class="section section--alt" id="how-it-works">
  <div class="wrap">
    <div class="center">
      <span class="eyebrow">{{ section.settings.eyebrow }}</span>
      <h2>{{ section.settings.heading }}</h2>
      <p class="lead">{{ section.settings.subheading }}</p>
    </div>
    <div class="steps">
      {% for block in section.blocks %}
        <div class="step" {{ block.shopify_attributes }}>
          <div class="step__n">{{ forloop.index }}</div>
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.body }}</p>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "How it works",
  "settings": [
    { "type": "text", "id": "eyebrow", "label": "Eyebrow", "default": "How it works" },
    { "type": "text", "id": "heading", "label": "Heading", "default": "Open it. Navigate it. Find anything." },
    { "type": "textarea", "id": "subheading", "label": "Subheading", "default": "Every file is memory-mapped and parsed once into a compact index — only the rows on screen are ever built." }
  ],
  "blocks": [
    { "type": "step", "name": "Step", "settings": [
      { "type": "text", "id": "title", "label": "Title", "default": "Step" },
      { "type": "textarea", "id": "body", "label": "Body" }
    ]}
  ],
  "presets": [{
    "name": "How it works",
    "blocks": [
      { "type": "step", "settings": { "title": "Open the file", "body": "Drag in a JSON, NDJSON, XML, CSV or TSV file up to ~10 GB — or paste from the clipboard or fetch a URL with auth. It opens instantly, no progress bars." } },
      { "type": "step", "settings": { "title": "Navigate the tree", "body": "Everything renders as one uniform, virtualized tree. Jump to any path, bookmark nodes, and read collapsed counts like “products : […], 31 items”." } },
      { "type": "step", "settings": { "title": "Search & export", "body": "Regex find, live filter, or JSONPath / XPath queries backed by parallel native search. Then export or convert to JSON, XML or CSV." } }
    ]
  }]
}
{% endschema %}
