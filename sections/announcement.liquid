{% if section.settings.show %}
<div class="announcement">
  {{ section.settings.text }}
  {% if section.settings.link_text != blank %}
    <a href="{{ section.settings.link_url | default: pages.pricing.url | default: '/pages/pricing' }}">{{ section.settings.link_text }} &rarr;</a>
  {% endif %}
</div>
{% endif %}

{% schema %}
{
  "name": "Announcement bar",
  "settings": [
    { "type": "checkbox", "id": "show", "label": "Show announcement", "default": true },
    { "type": "text", "id": "text", "label": "Text", "default": "New: Narik Edition — unlimited file size + auto-updates." },
    { "type": "text", "id": "link_text", "label": "Link text", "default": "See editions" },
    { "type": "url", "id": "link_url", "label": "Link URL" }
  ],
  "presets": [{ "name": "Announcement bar" }]
}
{% endschema %}
