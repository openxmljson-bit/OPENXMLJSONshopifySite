{% layout none %}<!doctype html>
<html lang="{{ request.locale.iso_code }}">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ shop.name }} — Opening soon</title>
  {{ content_for_header }}
  {{ 'base.css' | asset_url | stylesheet_tag }}
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
</head>
<body>
  <section class="wrap" style="min-height:100vh;display:grid;place-items:center;text-align:center">
    <div style="max-width:460px">
      <img src="{% if settings.logo != blank %}{{ settings.logo | image_url: width: 120 }}{% else %}{{ 'logo.png' | asset_url }}{% endif %}" width="64" style="margin:0 auto 20px;border-radius:16px">
      <h1>{{ shop.name }}</h1>
      <p class="lead" style="margin:0 auto 24px">Opening soon. Enter the password to preview.</p>
      {% form 'storefront_password' %}
        {{ form.errors | default_errors }}
        <div style="display:flex;gap:8px;max-width:360px;margin:0 auto">
          <input type="password" name="password" placeholder="Password" required
            style="flex:1;background:var(--surface);border:1px solid var(--border);border-radius:999px;padding:12px 18px;color:var(--text)">
          <button type="submit" class="btn btn--primary">Enter</button>
        </div>
      {% endform %}
    </div>
  </section>
</body>
</html>
