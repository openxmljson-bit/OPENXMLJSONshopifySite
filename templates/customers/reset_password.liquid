<section class="hero" style="padding:72px 0 24px">
  <div class="wrap hero__inner center">
    <span class="eyebrow">Account</span>
    <h1>Set a new password</h1>
    <p class="lead" style="margin:14px auto 0">Choose a new password for your account.</p>
  </div>
</section>

<section class="section" style="padding-top:8px">
  <div class="wrap" style="max-width:440px">
    {% form 'reset_customer_password' %}
      {{ form.errors | default_errors }}
      <div style="display:grid;gap:14px">
        <input type="password" name="customer[password]" placeholder="New password" autocomplete="new-password" required
          style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:13px 15px;color:var(--text)">
        <input type="password" name="customer[password_confirmation]" placeholder="Confirm new password" autocomplete="new-password" required
          style="background:var(--surface);border:1px solid var(--border);border-radius:10px;padding:13px 15px;color:var(--text)">
        <button type="submit" class="btn btn--primary btn--lg btn--block">Reset password</button>
      </div>
    {% endform %}
  </div>
</section>
